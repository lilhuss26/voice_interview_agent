# Image for the email → GitHub issue pipeline (pipeline/), which runs as its
# OWN Railway service, separate from the Flask voice-interview app.
#
# Deliberately does NOT install ffmpeg/libportaudio2 or bake Whisper weights —
# none of that is on this service's code path. See ./Dockerfile for the app.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN useradd --create-home --uid 1000 app && chown app:app /app

# Install as root into the SYSTEM site-packages, not ~/.local. The entrypoint
# switches users at the last moment, so a per-user install would land in
# /root/.local and be invisible to `app`.
COPY requirments.txt .
RUN pip install -r requirments.txt

COPY --chown=app:app . .

# DB_PATH should point at a mounted Railway volume (e.g. /data/pipeline.db) so
# last_history_id and the dedup table survive a redeploy. On ephemeral storage
# a restart re-seeds the cursor and silently skips whatever arrived meanwhile.
ENV PORT=8000

EXPOSE 8000

# Stays root just long enough to chown the runtime-mounted volume, then execs
# the server as uid 1000. See docker-entrypoint-pipeline.sh.
COPY --chmod=0755 docker-entrypoint-pipeline.sh /usr/local/bin/
ENTRYPOINT ["/usr/local/bin/docker-entrypoint-pipeline.sh"]
