# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Voice interview app (existing) ---
ANTHROPIC_API_KEY=
HOST=127.0.0.1
PORT=4567
DEBUG=1

# --- Email → GitHub issue pipeline ---

# Gmail OAuth. credentials.json is the desktop OAuth client downloaded from
# Google Cloud. The token is minted once locally by pipeline/scripts/list_recent.py.
GMAIL_CREDENTIALS=credentials.json
GMAIL_TOKEN=pipeline/token.json

# Production only. Base64 of a token.json minted locally:
#   base64 -w0 pipeline/token.json
# Decoded to GMAIL_TOKEN on boot so the container never opens a browser.
GMAIL_TOKEN_B64=

# Local default below; in production point this at a Railway volume,
# e.g. DB_PATH=/data/pipeline.db
DB_PATH=pipeline/pipeline.db

PUBSUB_TOPIC=projects/project-61db8653-da57-4d8e-a2f/topics/gmail-notifications

# Must exactly match the push endpoint configured on the Pub/Sub subscription —
# it is the audience the OIDC JWT is verified against. Unknown until the
# pipeline service has a Railway domain.
WEBHOOK_AUDIENCE=https://<pipeline>.up.railway.app/gmail/webhook

# Optional hardening: once known, set to the service account Pub/Sub signs as,
# and the webhook additionally checks the token's email claim.
PUBSUB_SA_EMAIL=

# Senders allowed to open issues. Comma-separated, case-insensitive.
# Add hassom20042019@gmail.com to test by emailing yourself.
ALLOWLIST=h.m.elnemr@gmail.com,mohamed.ramadan@aman.eg

GITHUB_TOKEN=
GITHUB_REPO=lilhuss26/voice_interview_agent

# Set to 1 to call users.watch() and start the daily renewal job on startup.
# Left off by default so importing pipeline.app never touches the network.
PIPELINE_AUTOWATCH=0
